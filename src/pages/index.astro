---
const skills = [
  'Product strategy',
  'Prototyping',
  'TypeScript',
  'React',
  'Design systems',
  'AI tooling',
  'User research',
  'Shipping fast',
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Andrew Maudsley — Product Engineer building thoughtful software." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Andrew Maudsley — Product Engineer</title>
  </head>
  <body>
    <main>
      <header class="hero">
        <h1>Andrew Maudsley</h1>
        <p class="role">Product Engineer</p>
        <p class="lede">
          I design and build software that feels obvious. Equal parts product
          thinking, design sense and engineering — shipping useful things end to end.
        </p>
        <nav class="nav">
          <a href="#about" class="pill">About</a>
          <a href="#contact" class="pill">Contact</a>
        </nav>
      </header>

      <section id="about" class="section">
        <h2>About</h2>
        <p>
          I've spent the last decade making digital products — moving between
          design, code and product strategy depending on what the work needs.
          I like small teams, sharp problems and shipping early.
        </p>
        <p>
          Lately I'm focused on AI-native tools, learning experiences for kids,
          and the quiet craft of interfaces that get out of the way.
        </p>
        <ul class="pills" aria-label="Skills">
          {skills.map((s) => <li class="pill pill--soft">{s}</li>)}
        </ul>
      </section>

      <section id="contact" class="section">
        <h2>Contact</h2>
        <p>
          The best way to reach me is by email. I read everything and reply to most.
        </p>
        <div class="contact">
          <a class="pill pill--mint" href="mailto:andrew@andrewmaudsley.com">
            andrew@andrewmaudsley.com
          </a>
          <a class="pill" href="https://github.com/andrewmaudsley" rel="me">GitHub</a>
          <a class="pill" href="https://www.linkedin.com/in/andrewmaudsley" rel="me">LinkedIn</a>
        </div>
      </section>

      <footer class="footer">
        <span>© {new Date().getFullYear()} Andrew Maudsley</span>
      </footer>
    </main>

    <style is:global>
      :root {
        --bg: #fbf8f3;
        --surface: #ffffff;
        --ink: #1f2430;
        --ink-soft: #5b6172;
        --line: #ece7dd;

        --accent: #ff7a59;     /* warm coral */
        --accent-soft: #ffe6dd;
        --mint: #7bc6a4;
        --mint-soft: #dff2e8;
        --sky: #8aa9e6;
        --sky-soft: #e2ebfb;
        --sun: #f6c453;
        --sun-soft: #fbeccd;

        --radius: 999px;
        --radius-card: 18px;

        --font-sans: ui-sans-serif, system-ui, -apple-system, "Segoe UI",
          "Inter", Roboto, "Helvetica Neue", Arial, sans-serif;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--font-sans);
        font-size: 17px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      main {
        max-width: 720px;
        margin: 0 auto;
        padding: 64px 24px 96px;
      }

      h1, h2, h3 { color: var(--ink); letter-spacing: -0.01em; }
      h1 { font-size: 2.4rem; margin: 16px 0 4px; line-height: 1.1; }
      h2 { font-size: 1.25rem; margin: 0 0 16px; }
      h3 { font-size: 1.05rem; margin: 0; }
      p  { margin: 0 0 14px; color: var(--ink-soft); }

      a { color: inherit; text-decoration: none; }

      .hero { margin-bottom: 56px; }
      .role {
        margin: 0 0 16px;
        color: var(--ink);
        font-weight: 500;
      }
      .lede { font-size: 1.05rem; max-width: 56ch; }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 24px;
      }

      .section {
        padding: 32px 0;
        border-top: 1px solid var(--line);
      }

      .pill {
        display: inline-flex;
        align-items: center;
        padding: 6px 14px;
        border-radius: var(--radius);
        background: var(--surface);
        border: 1px solid var(--line);
        font-size: 0.9rem;
        color: var(--ink);
        transition: transform 120ms ease, background 120ms ease;
      }
      a.pill:hover { transform: translateY(-1px); background: #fffdf8; }

      .pill--soft   { background: var(--sky-soft);  border-color: transparent; color: #2c3e6b; }
      .pill--mint   { background: var(--mint-soft); border-color: transparent; color: #2f6b51; }
      .pill--accent { background: var(--accent-soft); border-color: transparent; color: #9c3b22; }

      .pills {
        list-style: none;
        padding: 0;
        margin: 20px 0 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .work {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 12px;
      }
      .work__item {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: var(--radius-card);
        padding: 18px 20px;
      }
      .work__head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 6px;
      }
      .work__item p { margin: 0; }

      .contact {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 4px;
      }

      .footer {
        margin-top: 56px;
        padding-top: 24px;
        border-top: 1px solid var(--line);
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        color: var(--ink-soft);
      }

      @media (max-width: 520px) {
        h1 { font-size: 2rem; }
        main { padding: 40px 20px 72px; }
        .footer { flex-direction: column; gap: 6px; }
      }
    </style>
  </body>
</html>
