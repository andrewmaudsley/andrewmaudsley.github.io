---
const email = 'andrew@andrewmaudsley.com';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Andrew Maudsley — Product Engineer building a frontier AI product for private clinicians."
    />
    <link rel="icon" href="/favicon.ico?v=2" sizes="32x32" />
    <link rel="icon" href="/icon.svg?v=2" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>Andrew Maudsley — Product Engineer</title>
    <style is:global>
      :root {
        --bg: #f6f3ec;
        --surface: #ede9df;
        --ink: #1f2420;
        --ink-soft: #5b615b;
        --ink-mute: #8a8f87;
        --rule: #dfdacd;

        --accent: #5a6a4a;
        --accent-soft: #d2d6c4;
        --accent-hover: #bfc6ad;
        --accent-deep: #3d4a30;

        --serif: 'Source Serif 4', Georgia, serif;
        --sans: 'Inter Tight', ui-sans-serif, system-ui, sans-serif;
        --mono: 'JetBrains Mono', ui-monospace, monospace;
        --maxw: 640px;
        --gap-y: 56px;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 16px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings: "ss01", "cv11";
      }

      a { color: inherit; text-decoration: none; }
      ::selection { background: var(--accent); color: var(--bg); }

      .page {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(48px, 9vw, 96px) 28px clamp(64px, 10vw, 120px);
      }

      header.intro { margin-bottom: var(--gap-y); }

      .name {
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(34px, 5vw, 44px);
        line-height: 1.0;
        letter-spacing: -0.015em;
        margin: 0 0 10px;
        color: var(--ink);
      }
      .meta-line {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-family: var(--sans);
        font-size: 14px;
        letter-spacing: 0.01em;
        color: var(--ink-soft);
        font-weight: 500;
        margin: 0 0 28px;
      }
      .meta-line .dot {
        width: 6px; height: 6px; border-radius: 50%;
        background: var(--accent);
        display: inline-block;
      }
      .lede {
        font-family: var(--serif);
        font-style: italic;
        font-size: clamp(18px, 2.2vw, 21px);
        line-height: 1.45;
        color: var(--ink);
        margin: 0 0 28px;
        hyphens: none;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 999px;
        border: 1px solid var(--rule);
        background: transparent;
        font-size: 13.5px;
        line-height: 1.55;
        color: var(--accent);
        font-family: var(--sans);
        font-weight: 500;
        cursor: pointer;
        transition: border-color .2s ease, color .2s ease, background .2s ease, opacity .2s ease;
      }
      .pill:hover { border-color: var(--accent); }
      .pill[data-primary] {
        background: var(--accent);
        border: 1px solid var(--accent);
        color: var(--bg);
      }
      .pill[data-primary]:hover {
        background: var(--accent-deep);
        border-color: var(--accent-deep);
        color: var(--bg);
      }

      hr.rule {
        border: 0;
        border-top: 1px solid var(--rule);
        margin: var(--gap-y) 0;
        max-width: 100%;
      }

      section h2 {
        font-family: var(--serif);
        font-weight: 400;
        font-size: 22px;
        letter-spacing: -0.005em;
        color: var(--ink);
        margin: 0 0 18px;
      }

      section p {
        margin: 0 0 14px;
        color: var(--ink);
      }

      .contact-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 52px;
      }

      @media (max-width: 520px) {
        .contact-row {
          flex-direction: column;
          align-items: stretch;
        }
        .contact-row .pill {
          width: 100%;
          justify-content: center;
          padding: 12px 14px;
        }
        #contact + hr.rule { margin-top: calc(var(--gap-y) + 16px); }
      }

      footer.foot {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 16px;
        font-size: 12.5px;
        color: var(--ink-mute);
        font-family: var(--sans);
      }
    </style>
  </head>
  <body>
    <main class="page">
      <header class="intro">
        <h1 class="name">Andrew Maudsley</h1>
        <div class="meta-line">
          <span>Product Engineer</span>
          <span class="dot" aria-hidden="true"></span>
          <span>London</span>
        </div>
        <p class="lede">
          I love the craft. Solving problems, creating meaningful experiences and building products people want.
        </p>
      </header>

      <hr class="rule" />

      <section id="about">
        <h2>What I'm building</h2>
        <p>An AI native frontier tool for private clinicians.</p>
      </section>

      <hr class="rule" />

      <section id="how">
        <h2>How I'm building</h2>
        <p>
          By leaning heavily into AI design and engineering workflows, creating more time for cx, relationships and strategy.
        </p>
      </section>

      <hr class="rule" />

      <section id="work">
        <h2>Who I've worked with</h2>
        <p>BCG Digital Ventures, NYSE, E.ON Next, British Gas, John Lewis and Partners.</p>
      </section>

      <hr class="rule" />

      <section id="contact">
        <h2>Worth a chat?</h2>
        <p>Email is best — I read everything and reply to most.</p>
        <div class="contact-row">
          <button class="pill" data-primary id="emailBtn" type="button">
            <span id="emailLabel">{email}</span>
          </button>
          <a
            href="https://github.com/andrewmaudsley"
            class="pill"
            target="_blank"
            rel="noopener noreferrer"
          >GitHub</a>
          <a
            href="https://www.linkedin.com/in/andrewmaudsley"
            class="pill"
            target="_blank"
            rel="noopener noreferrer"
          >LinkedIn</a>
        </div>
      </section>

      <hr class="rule" />

      <footer class="foot">
        <div>© {new Date().getFullYear()} Andrew Maudsley</div>
      </footer>
    </main>

    <script is:inline define:vars={{ email }}>
      const btn = document.getElementById('emailBtn');
      const label = document.getElementById('emailLabel');
      const original = email;
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(original);
          label.textContent = 'Copied to clipboard ✓';
          setTimeout(() => { label.textContent = original; }, 1600);
        } catch {
          window.location.href = 'mailto:' + original;
        }
      });
    </script>
  </body>
</html>
